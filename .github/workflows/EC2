name: Deploy Portfolio App to Azure

on:
  push:
    branches: [ main ]
  workflow_dispatch:

jobs:
  # ================================
  # 1️⃣ Build & Push Docker Image
  # ================================
  build:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write   # for GHCR
      id-token: write   # for Azure OIDC login
    outputs:
      image-sha: ${{ steps.set-image.outputs.image-sha }}

    steps:
      # Checkout code
      - name: Checkout repo
        uses: actions/checkout@v4

      # Login to GHCR
      - name: Login to GHCR
        uses: docker/login-action@v3
        with:
          registry: ghcr.io
          username: ${{ github.repository_owner }}
          password: ${{ secrets.GITHUB_TOKEN }}

      # Build Docker image
      - name: Build Docker image
        id: set-image
        run: |
          IMAGE_SHA=${GITHUB_SHA}
          docker build -t ghcr.io/websitematthewengineering/portfolio:latest \
                       -t ghcr.io/websitematthewengineering/portfolio:$IMAGE_SHA ./portfolio/.
          echo "IMAGE_SHA=$IMAGE_SHA" >> $GITHUB_ENV
          echo "::set-output name=image-sha::$IMAGE_SHA"

      # Push Docker image
      - name: Push Docker image
        run: |
          docker push ghcr.io/websitematthewengineering/portfolio:latest
          docker push ghcr.io/websitematthewengineering/portfolio:${{ env.IMAGE_SHA }}

  # ================================
  # 2️⃣ Deploy to EC2
  # ================================
  deploy:
    runs-on: ubuntu-latest
    needs: build

    steps:
      - name: Deploy to EC2 via SSH
        uses: appleboy/ssh-action@v1.0.3
        with:
          host: ${{ secrets.EC2_HOST }}
          username: ubuntu
          key: ${{ secrets.EC2_SSH_KEY }}
          script: |
            set -e

            IMAGE=ghcr.io/websitematthewengineering/portfolio:${{ needs.build.outputs.image-sha }}

            echo "Logging into GHCR..."
            echo ${{ secrets.GHCR_PAT }} | docker login ghcr.io -u ${{ github.repository_owner }} --password-stdin

            echo "Pulling latest image..."
            docker pull $IMAGE

            echo "Stopping old container..."
            docker stop portfolio || true
            docker rm portfolio || true

            echo "Starting new container..."
            docker run -d \
              --name portfolio \
              -p 80:8000 \
              --restart unless-stopped \
              $IMAGE

            echo "Cleaning up old images..."
            docker image prune -f
